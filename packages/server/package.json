{
  "name": "server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun run db:generate && bun build src/index.ts --outdir dist --target bun",
    "start": "bun run db:migrate:prod && bun dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.13",
    "@prisma/client": "^6.10.1",
    "@sendgrid/inbound-mail-parser": "^8.0.0",
    "@sentry/node": "^10.65.0",
    "ai": "^7.0.26",
    "better-auth": "^1.6.23",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "multer": "^2.2.0",
    "pg-boss": "^12.26.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.2",
    "@types/multer": "^2.2.0",
    "prisma": "^6.10.1",
    "typescript": "~6.0.2"
  },
  "prisma": {
    "seed": "bun src/seed.ts"
  }
}
